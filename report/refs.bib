@article{liu-etal-2026,
title = {Improving cross-lingual dependency parsing via LLM-based transferring and self-optimizing synthetic data augmentation},
journal = {Expert Systems with Applications},
volume = {315},
pages = {131600},
year = {2026},
issn = {0957-4174},
doi = {https://doi.org/10.1016/j.eswa.2026.131600},
url = {https://www.sciencedirect.com/science/article/pii/S0957417426005130},
author = {Jianjian Liu and Ying Li and Zhengtao Yu and Yuxin Huang and Shengxiang Gao},
keywords = {Dependency parsing, Large language model, Transfer learning, Self-optimizing, Synthetic data construction},
abstract = {Large language models (LLMs) exhibit strong generation and representation capabilities in high-resource languages but face challenges in low-resource languages due to data scarcity and syntactic structural variations. To address this, we propose an LLM-driven method for transferring and self-optimizing synthetic data augmentation in cross-lingual dependency parsing. First, we integrate syntactically enhanced LLMs with traditional parsers to automatically generate two pseudo datasets for low-resource languages. The LLMs then iteratively refine these datasets to enhance their syntactic accuracy and consistency. In addition, we evaluate the efficacy and diversity of our synthetic data using three traditional parsers and six widely used LLMs. Experimental results on four benchmark datasets demonstrate that our approach significantly improves baseline models, achieving state-of-the-art performance on both traditional parsers and LLMs. Further analysis and manual evaluation confirm that our method effectively integrates the syntactic strengths of both systems, yielding more precise and realistic data. Our synthetic data and code have been made publicly11https://github.com/Flamelunar/LLMtransfer-parsing available.}
}



